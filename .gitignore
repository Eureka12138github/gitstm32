# ============================================================
# STM32 Standard Peripheral Library - Git Ignore Rules
# 针对 Keil MDK-ARM 项目的完整忽略规则
# ============================================================

# ------------------------------------------------------------
# 1. Keil MDK 编译产物（必须忽略）
# ------------------------------------------------------------
# 目标文件和中间文件
*.o
*.obj
*.d
*.crf
*.i
*.s

# 链接输出文件
*.axf
*.hex
*.bin
*.map
*.htm
*.lst
*.lnp

# 编译临时文件
*.bak
*.tmp
*.log

# Keil 输出目录
Objects/
Object/
Listings/
Listing/
build/
Build/

# ------------------------------------------------------------
# 2. Keil 工程配置文件（本地配置，不应提交）
# ------------------------------------------------------------
# 用户特定配置（含窗口布局、调试器设置等）
*.uvoptx
*.uvopt
*.uvguix.*
*.uvprojx.user

# 备份文件
*.uvprojx.bak
*.uvoptx.bak

# 设备数据库缓存
UVDE.TMP

# ------------------------------------------------------------
# 3. 调试器相关文件
# ------------------------------------------------------------
# J-LINK 调试日志
JLinkLog.txt
JLinkSettings.ini

# ST-LINK 配置
STLinkSettings.ini

# 调试追踪文件
*.trace
EventRecorder*.dat

# ------------------------------------------------------------
# 4. IDE 和编辑器临时文件
# ------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# IntelliJ IDEA / CLion
.idea/
*.iml

# Eclipse
.project
.cproject
.settings/
*.cproject

# Windows 缩略图缓存
Thumbs.db

# macOS 系统文件
.DS_Store
._*

# ------------------------------------------------------------
# 5. 文档和图片（可选，根据项目需要调整）
# ------------------------------------------------------------
# 如果图片用于文档说明，建议保留
# *.png
# *.jpg
# *.jpeg
# *.gif

# 但以下格式通常体积较大，建议忽略
*.bmp
*.tiff
*.psd

# ------------------------------------------------------------
# 6. 第三方工具和测试文件
# ------------------------------------------------------------
# VOFA+ 数据文件（通常体积较大）
*.voa
*.vofa

# 串口调试日志
*.txt.log
debug.log
uart_log.*

# ------------------------------------------------------------
# 7. 压缩包和备份目录
# ------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar.gz

# 以 "- 副本" 结尾的复制文件夹（手动清理）
# 注意：Git 无法直接忽略已跟踪的文件夹，需手动删除
# **/*- 副本/**

# ------------------------------------------------------------
# 8. 可执行文件和脚本（保留源码，忽略编译工具）
# ------------------------------------------------------------
# 除非是项目必需，否则忽略以下文件
# *.exe
# *.dll
# *.so

# ============================================================
# ⚠️ 重要提示：
# 1. 已跟踪的文件不会被 .gitignore 影响，需使用 git rm --cached 移除
# 2. 修改 .gitignore 后，建议使用 git status 验证效果
# 3. 如需清理已跟踪的编译产物，执行：
#    git rm -r --cached Objects/ Listings/ *.o *.axf *.hex
# ============================================================
